<UserControl x:Class="DesktopBox.Controls.ItemTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:DesktopBox.Models"
             MouseDoubleClick="OnDoubleClick"
             PreviewMouseRightButtonUp="OnPreviewMouseRightButtonUp"
             ToolTip="{Binding TargetPath}"
             Cursor="Hand">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <!-- 统一容器:用 StackPanel(可改方向) 承载 图标区 + 名称区 + 详情区 -->
    <Border x:Name="Root" Padding="3">
        <StackPanel x:Name="Panel" Orientation="Vertical">
            <!-- 图标区 -->
            <Grid x:Name="IconBox" Width="44" Height="44" HorizontalAlignment="Center">
                <Border x:Name="Fallback" CornerRadius="10">
                    <TextBlock x:Name="FallbackText"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Image x:Name="Img" Width="40" Height="40"
                       Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                       Source="{Binding IconCachePath}"/>
            </Grid>
            <!-- 名称区 -->
            <TextBlock x:Name="NameText" Text="{Binding DisplayName}"
                       Foreground="#FFEEEEEE" FontSize="11"
                       TextAlignment="Center" TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" Margin="0,3,0,0" MaxWidth="120"/>
            <!-- 详情区(仅详细信息/平铺用) -->
            <StackPanel x:Name="DetailBox" Orientation="Vertical" Visibility="Collapsed">
                <TextBlock x:Name="ModifiedText" Text="{Binding ModifiedText}"
                           Foreground="#FF999999" FontSize="9"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="SizeText" Text="{Binding SizeText}"
                           Foreground="#FF999999" FontSize="9"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
