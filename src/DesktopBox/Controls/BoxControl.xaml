<UserControl x:Class="DesktopBox.Controls.BoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:DesktopBox.Controls"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             ContextMenuOpening="OnContextMenuOpening">
    <Border x:Name="Card"
            Width="{Binding Width}"
            Height="{Binding Height}"
            CornerRadius="10"
            Background="#99000000"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏:鼠标按下可拖动整个盒子 -->
            <Border Grid.Row="0" Background="#66000000"
                    Padding="12,8"
                    MouseLeftButtonDown="OnHeaderDown"
                    MouseMove="OnHeaderMove"
                    MouseLeftButtonUp="OnHeaderUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Width="10" Height="10" RadiusX="2" RadiusY="2" Fill="#4FC3F7" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="White"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- 条目列表 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="72" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ctl:ItemTile/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 右下角缩放手柄 -->
            <Thumb Grid.Row="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Width="14" Height="14"
                   Cursor="SizeNWSE"
                   DragDelta="OnResize"/>
        </Grid>
    </Border>

    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="重命名盒子" Click="OnRename"/>
            <MenuItem Header="清空盒子" Click="OnClear"/>
            <Separator/>
            <MenuItem Header="删除盒子" Click="OnDelete"/>
        </ContextMenu>
    </UserControl.ContextMenu>
</UserControl>
