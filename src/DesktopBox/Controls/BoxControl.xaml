<UserControl x:Class="DesktopBox.Controls.BoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:DesktopBox.Controls"
             xmlns:m="clr-namespace:DesktopBox.Models"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             LostMouseCapture="OnLostMouseCapture"
             ContextMenuOpening="OnContextMenuOpening">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <ctl:EnumEqualityToBoolConverter x:Key="ModeEqual"/>
        <ctl:BoolToEyeStrokeConverter x:Key="BoolToEyeBrush"/>
        <ctl:BoolToEyeFillConverter x:Key="BoolToEyeFill"/>
    </UserControl.Resources>
    <Border x:Name="Card"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="10"
            Background="#99000000"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏:鼠标按下可拖动整个盒子 -->
            <Border Grid.Row="0" Background="#66000000"
                    Padding="12,8"
                    MouseLeftButtonDown="OnHeaderDown"
                    MouseMove="OnHeaderMove"
                    MouseLeftButtonUp="OnHeaderUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Width="10" Height="10" RadiusX="2" RadiusY="2" Fill="#4FC3F7" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Header}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="White"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <!-- 显示/隐藏桌面图标快捷按钮:眼睛图标,显示=亮色实心,隐藏=暗色空心 -->
                    <Button Grid.Column="2"
                            x:Name="ToggleIconsBtn"
                            Click="OnToggleDesktopIcons"
                            ToolTip="{DynamicResource tip.toggleIcons}"
                            Width="24" Height="24" Margin="6,0,0,0" Padding="0"
                            Background="Transparent"
                            BorderBrush="#66FFFFFF"
                            Cursor="Hand"
                            Tag="{Binding MainVm.DesktopIconsVisible, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Path Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              StrokeThickness="1.6"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag, Converter={StaticResource BoolToEyeBrush}}"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag, Converter={StaticResource BoolToEyeFill}}"
                              Data="M12,5C5,5 1,12 1,12C1,12 5,19 12,19C19,19 23,12 23,12C23,12 19,5 12,5 Z M12,9A3,3 0 1,0 12,15A3,3 0 1,0 12,9 Z"/>
                    </Button>
                </Grid>
            </Border>

            <!-- 标签行(仅标签模式可见) -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsTabbed, Converter={StaticResource BoolVis}}"
                  Background="#33000000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ListBox x:Name="TabList" Grid.Column="0"
                         ItemsSource="{Binding Tabs}"
                         SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Focusable="False"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="OnTabListMouseDown"
                         PreviewMouseMove="OnTabListMouseMove"
                         DragOver="OnTabListDragOver"
                         Drop="OnTabListDrop"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,4"/>
                            <Setter Property="Margin" Value="2,3"/>
                            <Setter Property="Foreground" Value="#FFCCCCCC"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#665599FF"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Header}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Column="1" Content="+"
                        Width="24" Height="22" Margin="2,3,8,3"
                        FontSize="16" Padding="0"
                        Click="OnAddTab" ToolTip="{DynamicResource tip.newTab}"/>
            </Grid>

            <!-- 条目列表(当前标签 / Items):按 ViewMode 切换布局 -->
            <ScrollViewer x:Name="ItemsScroll"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent"
                          PreviewMouseLeftButtonDown="OnItemsAreaMouseDown"
                          Padding="4">
                <Grid x:Name="ItemsViewport"
                      Width="{Binding ElementName=ItemsScroll, Path=ViewportWidth}"
                      Background="Transparent">
                    <!-- 大图标:默认(大方块) -->
                    <ItemsControl ItemsSource="{Binding DisplayItems}"
                                  Visibility="{Binding IsLarge, Converter={StaticResource BoolVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel ItemWidth="100" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><ctl:ItemTile IconSize="Large"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 中等图标 -->
                    <ItemsControl ItemsSource="{Binding DisplayItems}"
                                  Visibility="{Binding IsMedium, Converter={StaticResource BoolVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel ItemWidth="84" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><ctl:ItemTile IconSize="Medium"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 小图标(横向流式,16px 图标 + 名称) -->
                    <ItemsControl ItemsSource="{Binding DisplayItems}"
                                  Visibility="{Binding IsSmall, Converter={StaticResource BoolVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><ctl:ItemTile IconSize="Small"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 列表(纵向单列) -->
                    <ItemsControl ItemsSource="{Binding DisplayItems}"
                                  Visibility="{Binding IsList, Converter={StaticResource BoolVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><ctl:ItemTile IconSize="Small"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 详细信息:名称/修改时间/大小 -->
                    <ItemsControl ItemsSource="{Binding DisplayItems}"
                                  Visibility="{Binding IsDetail, Converter={StaticResource BoolVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><ctl:ItemTile IconSize="Detail"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 平铺(图标+名称,横向卡片) -->
                    <ItemsControl ItemsSource="{Binding DisplayItems}"
                                  Visibility="{Binding IsTile, Converter={StaticResource BoolVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><ctl:ItemTile IconSize="Tile"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- 八方向缩放手柄:覆盖卡片边缘。中间透明区域 hit-test 穿透到下层,不影响交互。 -->
            <Grid Grid.Row="0" Grid.RowSpan="3" Margin="0">
                <Grid.Resources>
                    <Style TargetType="Thumb">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Thumb">
                                    <Rectangle Fill="Transparent"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Width="18"
                        Height="18"
                        Margin="0,0,5,5"
                        IsHitTestVisible="False"
                        Opacity="0.55">
                    <Canvas>
                        <Line X1="14" Y1="4" X2="4" Y2="14" Stroke="#CCFFFFFF" StrokeThickness="1"/>
                        <Line X1="14" Y1="9" X2="9" Y2="14" Stroke="#CCFFFFFF" StrokeThickness="1"/>
                    </Canvas>
                </Border>
                <Thumb Tag="N"  HorizontalAlignment="Stretch" VerticalAlignment="Top"    Height="10" Cursor="SizeNS"   IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
                <Thumb Tag="S"  HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="18" Margin="12,0,12,4" Cursor="SizeNS"   IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
                <Thumb Tag="W"  VerticalAlignment="Stretch"   HorizontalAlignment="Left"  Width="10" Cursor="SizeWE"   IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
                <Thumb Tag="E"  VerticalAlignment="Stretch"   HorizontalAlignment="Right" Width="18" Margin="0,12,4,12" Cursor="SizeWE"   IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
                <Thumb Tag="NW" HorizontalAlignment="Left"  VerticalAlignment="Top"    Width="24" Height="24" Cursor="SizeNWSE" IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
                <Thumb Tag="SW" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Width="24" Height="24" Cursor="SizeNESW" IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
                <Thumb Tag="NE" HorizontalAlignment="Right" VerticalAlignment="Top"    Width="28" Height="28" Margin="0,4,4,0" Cursor="SizeNESW" IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
                <Thumb Tag="SE" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="28" Height="28" Margin="0,0,4,4" Cursor="SizeNWSE" IsHitTestVisible="True" DragStarted="OnResizeStarted" DragDelta="OnResize" DragCompleted="OnResizeCompleted"/>
            </Grid>
        </Grid>
    </Border>

    <UserControl.ContextMenu>
        <!-- ContextMenu 不在视觉树中,需显式绑定到 PlacementTarget(本控件)的 DataContext。
             Header 用 DynamicResource,语言切换时自动刷新。 -->
        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="{DynamicResource menu.view}">
                <MenuItem Header="{DynamicResource view.large}" Click="OnViewLarge" IsCheckable="True"
                          IsChecked="{Binding ViewMode, Converter={StaticResource ModeEqual}, ConverterParameter={x:Static m:ViewMode.Large}, Mode=OneWay}"/>
                <MenuItem Header="{DynamicResource view.medium}" Click="OnViewMedium" IsCheckable="True"
                          IsChecked="{Binding ViewMode, Converter={StaticResource ModeEqual}, ConverterParameter={x:Static m:ViewMode.Medium}, Mode=OneWay}"/>
                <MenuItem Header="{DynamicResource view.small}" Click="OnViewSmall" IsCheckable="True"
                          IsChecked="{Binding ViewMode, Converter={StaticResource ModeEqual}, ConverterParameter={x:Static m:ViewMode.Small}, Mode=OneWay}"/>
                <MenuItem Header="{DynamicResource view.list}" Click="OnViewList" IsCheckable="True"
                          IsChecked="{Binding ViewMode, Converter={StaticResource ModeEqual}, ConverterParameter={x:Static m:ViewMode.List}, Mode=OneWay}"/>
                <MenuItem Header="{DynamicResource view.detail}" Click="OnViewDetail" IsCheckable="True"
                          IsChecked="{Binding ViewMode, Converter={StaticResource ModeEqual}, ConverterParameter={x:Static m:ViewMode.Detail}, Mode=OneWay}"/>
                <MenuItem Header="{DynamicResource view.tile}" Click="OnViewTile" IsCheckable="True"
                          IsChecked="{Binding ViewMode, Converter={StaticResource ModeEqual}, ConverterParameter={x:Static m:ViewMode.Tile}, Mode=OneWay}"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource box.menu.rename}" Click="OnRename"/>
            <MenuItem Header="{DynamicResource box.menu.removeSelected}" Click="OnRemoveSelected"/>
            <MenuItem Header="{DynamicResource box.menu.clear}" Click="OnClear"/>
            <Separator/>
            <!-- 仅标签模式 -->
            <MenuItem Header="{DynamicResource box.menu.newTab}" Click="OnAddTab">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTabbed}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem Header="{DynamicResource box.menu.renameTab}" Click="OnRenameTab">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTabbed}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem Header="{DynamicResource box.menu.deleteTab}" Click="OnDeleteTab">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTabbed}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <!-- 仅普通模式 -->
            <MenuItem Header="{DynamicResource box.menu.toTabbed}" Click="OnConvertToTabbed">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTabbed}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <!-- 仅标签模式 -->
            <MenuItem Header="{DynamicResource box.menu.mergeIn}" Click="OnMergeIn">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTabbed}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem Header="{DynamicResource box.menu.split}" Click="OnSplit">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTabbed}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <Separator/>
            <MenuItem Header="{DynamicResource box.menu.delete}" Click="OnDelete"/>
        </ContextMenu>
    </UserControl.ContextMenu>
</UserControl>
