<Window x:Class="DesktopBox.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DesktopBox.ViewModels"
        xmlns:ctl="clr-namespace:DesktopBox.Controls"
        Title="DesktopBox"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True">
    <Canvas x:Name="Layer" Background="Transparent" ClipToBounds="False">
        <Canvas.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource menu.newBox}" Click="OnNewBox"/>
                <MenuItem Header="{DynamicResource menu.addSysIcons}" Click="OnAddSystemIcons"/>
                <MenuItem Header="{DynamicResource menu.organize}" Click="OnOrganize" FontWeight="SemiBold"/>
                <MenuItem Header="{DynamicResource menu.toggleIcons}" Click="OnToggleIcons"/>
                <MenuItem Header="{DynamicResource menu.settings}" Click="OnOpenSettings"/>
                <Separator/>
                <MenuItem Header="{DynamicResource menu.quit}" Click="OnQuit"/>
            </ContextMenu>
        </Canvas.ContextMenu>
        <ItemsControl ItemsSource="{Binding Boxes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:BoxViewModel}">
                    <ctl:BoxControl/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Canvas>
</Window>
