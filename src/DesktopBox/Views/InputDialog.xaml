<Window x:Class="DesktopBox.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopBox"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1F1F1F"
        Foreground="White">
    <StackPanel Margin="18">
        <TextBlock x:Name="Message" Foreground="#FFE0E0E0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <TextBox x:Name="Input" FontSize="13" Padding="6,4" Background="#FF2B2B2B" Foreground="White" BorderBrush="#FF555555"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="OkButton" Content="确定" Click="OnOk" Padding="20,5" Margin="0,0,10,0"/>
            <Button x:Name="CancelButton" Content="取消" Click="OnCancel" Padding="20,5" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
