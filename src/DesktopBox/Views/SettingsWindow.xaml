<Window x:Class="DesktopBox.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopBox 设置"
        Width="400" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#FF1F1F1F"
        Foreground="White"
        Loaded="OnLoaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="通用" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <CheckBox Grid.Row="1" Content="开机自启动"
                  IsChecked="{Binding AutoStart}"
                  Margin="0,0,0,10" Foreground="White"/>

        <CheckBox Grid.Row="2" Content="跟随系统深浅色"
                  IsChecked="{Binding FollowSystemTheme}"
                  Margin="0,0,0,16" Foreground="White"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <TextBlock Text="主题:" VerticalAlignment="Center" Foreground="White" Margin="0,0,12,0"/>
            <RadioButton x:Name="DarkRadio" GroupName="Theme" Content="深色"
                         IsChecked="{Binding IsDark}" Foreground="White" Margin="0,0,16,0"/>
            <RadioButton x:Name="LightRadio" GroupName="Theme" Content="浅色" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="5" Text="设置即时生效并自动保存。"
                   Foreground="#FF9AA0A6" FontSize="11"/>
    </Grid>
</Window>
